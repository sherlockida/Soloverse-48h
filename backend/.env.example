# EchoWorld (SoloVerse) 后端环境变量模板
# 复制本文件为 .env 并填入真实值。.env 已被 .gitignore 忽略，不会提交。

# ===== LLM Provider (CLAUDE.md: 开发环境用 DeepSeek) =====
# 必填：从 https://platform.deepseek.com/ 获取
DEEPSEEK_API_KEY=

# 其他 OpenAI 兼容 provider（按需启用，留空则自动跳过）
# ZHIPU_API_KEY=
# MOONSHOT_API_KEY=
# QWEN_API_KEY=
# OLLAMA_API_KEY=

# 可选：覆盖单个 provider 的 base_url / model
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat

# ===== Provider 链（逗号分隔，按顺序尝试，最后兜底 mock）=====
# 默认: zhipu,moonshot,qwen,deepseek,ollama,mock
# 省 token 测试: deepseek,mock
LLM_PROVIDER_CHAIN=deepseek,mock

# ===== 省 token 调参（开发测试推荐）=====
# tick 间隔秒数（默认 8）。测试时设大（如 30）可降低 LLM 调用频率
TICK_INTERVAL_SECONDS=30
# 每 N tick 做一次叙事检测（默认 4）
NARRATIVE_EVERY_N_TICKS=8
# LLM 重试次数（默认 1）
LLM_MAX_RETRIES=1
# 单次 LLM 调用超时秒数（默认 30）
LLM_TIMEOUT_SECONDS=30
# 开发期 LLM 响应缓存（1=开，重复 prompt 不重复调用）
LLM_CACHE_ENABLED=1

# ===== HTTP 超时中间件 (P1-T7) =====
REQUEST_TIMEOUT=30
